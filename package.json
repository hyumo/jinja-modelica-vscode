{
  "name": "jinja-mo",
  "displayName": "Jinja Modelica",
  "description": "Jinja2 + Modelica syntax highlighting for .mo.jinja2 templates",
  "version": "0.1.2",
  "publisher": "hyumo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyumo/jinja-modelica-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "modelica",
    "jinja",
    "jinja2",
    "template",
    "mo"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jinja-modelica",
        "aliases": [
          "Jinja Modelica",
          "jinja-mo"
        ],
        "extensions": [
          ".mo.jinja2",
          ".mo.j2",
          ".mo.jinja"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jinja-modelica",
        "scopeName": "source.jinja.modelica",
        "path": "./syntaxes/jinja-modelica.tmLanguage.json",
        "embeddedLanguages": {
          "source.modelica": "modelica"
        }
      }
    ]
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "*"
  }
}
